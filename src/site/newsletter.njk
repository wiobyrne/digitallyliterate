---
layout: layouts/page.njk
title: Digitally Literate Newsletter
permalink: /newsletter/
eleventyExcludeFromCollections: true
contentClasses: dl-note dl-page dl-newsletter-archive
---
<header>
  <h1>Digitally Literate</h1>
  <p class="landing-subtitle">The complete newsletter archive — {{ collections.newsletter | length }} issues since 2015.</p>
</header>

<p>Digitally Literate follows the forces shaping how we read, write, learn, and live in digital spaces. Browse the complete archive here, or receive new issues by email.</p>

<p class="newsletter-subscribe-link"><a href="https://digitallyliterate.substack.com/">Subscribe on Substack <span aria-hidden="true">→</span></a></p>

<hr>

<h2>Recent Issues</h2>

<div class="landing-list">
  {%- for note in collections.newsletter -%}
    {%- if loop.index <= 10 -%}
      <div class="landing-item">
        <a href="{{ note.url }}">{{ note.data.title or note.fileSlug }}</a>
        {%- if note.data.description %} — {{ note.data.description }}{% endif %}
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<hr>

<h2>Full Archive</h2>

<div class="book-filters">
  <label for="newsletter-filter">Filter the archive by title</label>
  <input type="search" id="newsletter-filter" placeholder="Search issue titles" class="book-filter-input" autocomplete="off">
</div>

<div class="landing-list" id="newsletter-list">
  {%- for note in collections.newsletter -%}
    <div class="landing-item" data-title="{{ note.data.title | lower }}">
      <a href="{{ note.url }}">{{ note.data.title or note.fileSlug }}</a>
    </div>
  {%- endfor -%}
</div>

<script>
(function() {
  var items = Array.from(document.querySelectorAll('#newsletter-list .landing-item'));
  document.getElementById('newsletter-filter').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    items.forEach(function(item) {
      item.style.display = item.dataset.title.indexOf(q) !== -1 ? '' : 'none';
    });
  });
})();
</script>
