{% if settings.dgHomeLink === true %}
<header class="navbar garden-masthead">
  <p class="garden-masthead__line">A public notebook for ideas in motion</p>
  <a class="garden-masthead__wordmark" href="/" aria-label="{{ meta.siteName }} home">
    {% if meta.siteLogoPath %}
      <img class="site-logo" src="{{ meta.siteLogoPath }}" alt="{{ meta.siteName }}">
    {% else %}
      <span>{{ meta.siteName }}</span>
    {% endif %}
  </a>
  <nav class="garden-masthead__nav" aria-label="Primary navigation">
    <a href="/newsletter/">Newsletter</a>
    {% if settings.dgEnableSearch === true %}
      {% include "components/searchButton.njk" %}
    {% endif %}
    <button class="garden-theme-toggle" type="button" aria-pressed="false" aria-label="Use dark mode">
      <span class="garden-theme-toggle__label" aria-hidden="true">Dark</span>
    </button>
  </nav>
  <span class="garden-masthead__rule" aria-hidden="true"></span>
</header>
{% else %}
<div class="empty-navbar">
  {% if settings.dgEnableSearch === true %}
    {% include "components/searchButton.njk" %}
  {% endif %}
</div>
{% endif %}
