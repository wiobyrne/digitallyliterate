<!DOCTYPE html>
<html lang="{{ meta.mainLanguage or 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — {{ meta.siteName }}</title>

    {# Apparatus cascade — order is the contract; do not reorder #}
    <link rel="stylesheet" href="/styles/apparatus-colors.css">
    <link rel="stylesheet" href="/styles/apparatus-core.css">
    <link rel="stylesheet" href="/styles/apparatus-themes.css">
    <link rel="stylesheet" href="/styles/dl-extras.css">

    {% if meta.themeColor %}
    <meta name="theme-color" content="{{ meta.themeColor }}">
    {% endif %}
    {% favicons './src/site/favicon.svg', appleIconBgColor='#006d48' %}
  </head>
  <body data-theme="dl">

    <article class="essay" data-theme="dl">
      <header class="essay-header">

        {# Eyebrow #}
        <p class="essay-eyebrow">
          {% include "components/regmark.njk" %}
          <span>{{ eyebrow or "Note · evergreen" }}</span>
          {% if topic %}
            <span class="essay-eyebrow-dot">·</span>
            <span>{{ topic }}</span>
          {% endif %}
        </p>

        {# Title #}
        <h1 class="essay-title">{{ title }}</h1>

        {# Lede #}
        {% if lede %}
          <p class="essay-lede">{{ lede }}</p>
        {% endif %}

        {# Record block #}
        {% if record %}
          <dl class="record">
            {% for key, value in record %}
              <dt>{{ key }}</dt>
              <dd>{{ value }}</dd>
            {% endfor %}
          </dl>
        {% endif %}

      </header>

      {# Prose body #}
      <div class="essay-prose">
        {{ content | safe }}
      </div>

      {# Backlinks — visible connections at the bottom #}
      {% if backlinks and backlinks.length > 0 %}
        <section class="dl-backlinks">
          <h2 class="dl-backlinks-h">
            <span>Connects to</span>
            <span class="count">{{ backlinks | length }}</span>
          </h2>
          <ul class="dl-backlinks-list">
            {% for item in backlinks %}
              <li>
                <span class="src{% if item.isCross %} is-cross{% endif %}">{{ item.source }}</span>
                <p class="target">
                  <a href="{{ item.href }}">{{ item.title }}</a>
                  {% if item.quote %}
                    <span class="quote">{{ item.quote }}</span>
                  {% endif %}
                </p>
              </li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}

      {# Colophon CTA — the only conversion surface #}
      <div class="dl-colophon-cta">
        <span class="lead">Subscribe</span>
        <span class="body">{{ colophonLine or "A weekly thread on digital literacy, AI, and education." }}</span>
        <span class="arrow"><a href="https://digitallyliterate.substack.com">digitallyliterate.substack.com →</a></span>
      </div>

    </article>

  </body>
</html>
