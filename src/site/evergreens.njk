---
layout: layouts/page.njk
title: Evergreen Notes
permalink: /evergreens/
eleventyExcludeFromCollections: true
---
<header>
  <h1>Evergreen Notes</h1>
  <p class="landing-subtitle">Durable ideas — polished, reusable, and ready to share.</p>
</header>

<p><strong>Evergreens</strong> are durable, standalone explanations of ideas that recur across the Digitally Literate newsletter.</p>

<p class="book-count">{{ collections.evergreens | length }} evergreen notes</p>

{% if collections.evergreens | length %}<div class="book-filters">
  <label for="landing-filter">Filter Evergreen notes by title</label>
  <input type="search" id="landing-filter" placeholder="Search note titles" class="book-filter-input" autocomplete="off">
</div>

<div class="landing-list" id="landing-list">
  {%- for note in collections.evergreens -%}
    <div class="landing-item" data-title="{{ note.data.title | lower }}">
      <a href="{{ note.url }}">{% if note.data.title %}{{ note.data.title }}{% else %}{{ note.fileSlug }}{% endif %}</a>
    </div>
  {%- endfor -%}
</div>

<script>
(function() {
  var items = Array.from(document.querySelectorAll('.landing-item'));
  document.getElementById('landing-filter').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    items.forEach(function(item) {
      item.style.display = item.dataset.title.indexOf(q) !== -1 ? '' : 'none';
    });
  });
})();
</script>
{% else %}<p>This public collection is still being cultivated. The newsletter archive remains the best way into the work.</p>{% endif %}
