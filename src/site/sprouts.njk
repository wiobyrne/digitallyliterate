---
layout: layouts/page.njk
title: Sprout Notes
permalink: /sprouts/
eleventyExcludeFromCollections: true
---
<header>
  <h1>Sprout Notes</h1>
  <p class="landing-subtitle">Developing ideas shared deliberately while they take shape.</p>
</header>

<p><strong>Sprouts</strong> are developing notes. They stay private by default;
only notes deliberately selected for public reading appear here.</p>

<p class="book-count">{{ collections.sprouts | length }} sprout notes</p>

<div class="book-filters">
  <input type="text" id="landing-filter" placeholder="Filter by title..." class="book-filter-input" autocomplete="off">
</div>

<div class="landing-list" id="landing-list">
  {%- for note in collections.sprouts -%}
    <div class="landing-item" data-title="{{ note.data.title | lower }}">
      <a href="{{ note.url }}">{% if note.data.title %}{{ note.data.title }}{% else %}{{ note.fileSlug }}{% endif %}</a>
    </div>
  {%- endfor -%}
</div>

<script>
(function() {
  var items = Array.from(document.querySelectorAll('.landing-item'));
  document.getElementById('landing-filter').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    items.forEach(function(item) {
      item.style.display = item.dataset.title.indexOf(q) !== -1 ? '' : 'none';
    });
  });
})();
</script>
